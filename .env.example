# === Threads API (Meta) ===
THREADS_APP_ID=your_app_id
THREADS_APP_SECRET=your_app_secret
THREADS_ACCESS_TOKEN=your_long_lived_token
THREADS_USER_ID=your_user_id

# === Google Gemini ===
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# === Google Apps Script (Spreadsheet output) ===
GAS_WEBAPP_URL=your_gas_webapp_url

# === Post Generation ===
MAX_POST_LENGTH=500
DRAFT_COUNT=3

# === CTA Settings (optional) ===
CTA_FREQUENCY=5
CTA_URL=
CTA_SERVICE_NAME=
CTA_SERVICE_DESC=

# === Notification (optional) ===
SLACK_WEBHOOK_URL=
